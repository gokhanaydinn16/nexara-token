# ─── ANTHROPIC (Claude AI) ───────────────────────────────────────
# https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ─── TELEGRAM ────────────────────────────────────────────────────
# 1. Telegram'da @BotFather'a yaz
# 2. /newbot → isim ver → token al
TELEGRAM_BOT_TOKEN=7xxxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Günlük istatistik paylaşılacak kanal/grup ID'si
# Grupta /start yaz, bot size chat_id'yi söyler
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx

# ─── TWITTER / X ─────────────────────────────────────────────────
# developer.twitter.com → New App → Keys and Tokens
TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAxxxxx
TWITTER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxx
TWITTER_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITTER_ACCESS_TOKEN=xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITTER_ACCESS_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
